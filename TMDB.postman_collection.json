    {
      "name": "Search Movies by Keyword",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains results array\", function () {\r",
              "    pm.expect(jsonData.results).to.be.an('array');\r",
              "});\r",
              "\r",
              "pm.test(\"Validate movie titles are relevant to search keyword\", function () {\r",
              "    var searchKeyword = \"inception\";\r",
              "    if (jsonData.results && jsonData.results.length > 0) {\r",
              "        var firstMovieTitle = jsonData.results[0].title.toLowerCase();\r",
              "        pm.expect(firstMovieTitle).to.include(searchKeyword.toLowerCase());\r",
              "    } else {\r",
              "        pm.fail(\"Results array is empty or missing, cannot validate title relevance.\");\r",
              "    }\r",
              "});\r",
              "\r",
              "pm.test(\"Validate each result includes required keys (id, title, release_date, overview)\", function () {\r",
              "    if (jsonData.results && jsonData.results.length > 0) {\r",
              "        jsonData.results.forEach(function(movie) {\r",
              "            pm.expect(movie).to.have.property('id');\r",
              "            pm.expect(movie).to.have.property('title');\r",
              "            pm.expect(movie).to.have.property('release_date');\r",
              "            pm.expect(movie).to.have.property('overview');\r",
              "        });\r",
              "    } else {\r",
              "        pm.fail(\"Results array is empty or missing, cannot validate properties.\");\r",
              "    }\r",
              "});\r",
              "\r",
              "pm.test(\"Confirm total_results is greater than 0\", function () {\r",
              "    pm.expect(jsonData.total_results).to.be.above(0);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/search/movie?query=inception&language=en-US",
          "host": [
            "{{base_url}}"
          ],
          "path": [
